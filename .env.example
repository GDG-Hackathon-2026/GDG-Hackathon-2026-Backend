DOCKERHUB_USERNAME=your-dockerhub-id

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=gdg
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=gdg

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# GCP Vertex AI (Gemini 모델)
# Service Account JSON key는 EC2 ~/app/gcp-sa.json 에 직접 업로드. 이 리포에 커밋 금지.
# GOOGLE_CLOUD_PROJECT 가 비어있으면 /api/gemini/* 엔드포인트는 자동 비활성화.
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
