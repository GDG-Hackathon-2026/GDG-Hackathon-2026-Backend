DOCKERHUB_USERNAME=your-dockerhub-id

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=gdg
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=gdg

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# GCP Vertex AI (Gemini 모델)
# Service Account JSON key는 EC2 ~/app/gcp-sa.json 에 직접 업로드. 이 리포에 커밋 금지.
# GOOGLE_CLOUD_PROJECT 가 비어있으면 /api/gemini/* 및 /api/conversations/* 엔드포인트 자동 비활성화.
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# 생성 파라미터 (장황·창의적 답변 유도). 기본 1.0/0.95.
GEMINI_TEMPERATURE=1.2
GEMINI_TOP_P=0.95

# Firebase Authentication (Admin SDK)
# JSON key는 EC2 ~/app/firebase-sa.json 에 직접 업로드. 이 리포에 커밋 금지.
# 비어있으면 토큰 검증 필터 비활성 -> 모든 인증 필요 엔드포인트가 401.
FIREBASE_CREDENTIALS_PATH=/app/firebase-sa.json

# 개발·테스트 전용 Firebase 인증 우회.
# true 면 X-Dev-Uid 헤더로 Firebase 토큰 없이 요청 가능. 해커톤 종료 후 반드시 false 로.
DEV_AUTH_BYPASS=false

# 탄소 환산 상수 (gCO2eq / 1000 tokens). 데모 효과 위해 수치 조절 가능.
CARBON_G_PER_1K_INPUT=0.015
CARBON_G_PER_1K_OUTPUT=0.025
